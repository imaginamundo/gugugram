---
import ImageModal from "./ImageModal.svelte";
import { getImagePost, type PostType } from "@services/image";

const session = Astro.locals.user;

const postId = Astro.url.searchParams.get('post');
let post: PostType | null = null; 
if (postId) {
	post = await getImagePost(postId);
}
---

<ImageModal {session} {post} client:load />