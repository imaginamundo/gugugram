---
import { getProfile } from "@services/user/profile.ts";
import { getImagePosts } from "@services/imagePost";
import Layout from "@layout/Main.astro";
import ProfileHeader from "@components/profile/ProfileHeader/ProfileHeader.astro";
import ProfileTabs from "@components/profile/ProfileTabs/ProfileTabs.svelte";
import ImagePostList from "@components/post/ImagePostList/ImagePostList.astro";

const { username } = Astro.params;
if (!username) return new Response(null, { status: 404 });

const session = Astro.locals.user;

// getImagePosts only depends on `username`, so fetch it alongside the profile
// instead of waiting for the profile round-trip to finish first.
const [{ user, messagesCount, unreadMessagesCount, friendsCount, pendingFriendRequest }, images] =
	await Promise.all([getProfile({ username, session }), getImagePosts(username)]);

if (!user) return new Response(null, { status: 404 });

const seo = {
	title: `Imagens de ${username}`,
	description: `Suba suas imagens no Gugugram e adicione ${username} como amigo!`,
};
---

<Layout {...seo}>
	<ProfileHeader {user} />
	<ProfileTabs
		selectedTab="fotos"
		{username}
		{messagesCount}
		{friendsCount}
		{pendingFriendRequest}
		{unreadMessagesCount}
		client:load
	>
		<ImagePostList posts={images} />
	</ProfileTabs>
</Layout>
