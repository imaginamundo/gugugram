---
import Layout from "@layout/Main.astro";
import CommunityHeader from "@components/community/CommunityHeader/CommunityHeader.astro";
import CreatePostForm from "@components/community/CreatePostForm/CreatePostForm.svelte";
import { getCommunity, getSubscriber } from "@services/community";

const { slug } = Astro.params;
if (!slug) return new Response(null, { status: 404 });

const community = await getCommunity(slug);
if (!community) return new Response(null, { status: 404 });

const session = Astro.locals.user;

let isSubscribed = false;

if (session) {
	isSubscribed = await getSubscriber(community.id, session.id);
}

if (!isSubscribed) {
	return Astro.redirect(`/comunidades/${slug}`);
}

const isOwner = session?.id === community.ownerId;

const seo = {
	title: `${community.title} • Novo post`,
	description: community.description ?? `Comunidade ${community.title} no Gugugram.`,
};
---

<Layout {...seo}>
	<CommunityHeader {community} {isSubscribed} {isOwner} />
	<CreatePostForm communityId={community.id} communitySlug={slug} client:load />
</Layout>
