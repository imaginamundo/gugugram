---
import Layout from "@layout/Main.astro";
import CommunityPostDetail from "@components/community/CommunityPostDetail/CommunityPostDetail.astro";
import CreateResponseForm from "@components/community/CreateResponseForm/CreateResponseForm.svelte";
import CommunityHeader from "@components/community/CommunityHeader/CommunityHeader.astro";
import { getCommunity, getCommunityPostPaginated } from "@services/community";
import { communityRepository } from "@repositories/community";

const { slug, postId } = Astro.params;
if (!slug || !postId) return new Response(null, { status: 404 });

const community = await getCommunity(slug);
if (!community) return new Response(null, { status: 404 });

const pageParam = Astro.url.searchParams.get("page");
const page = Math.max(1, parseInt(pageParam ?? "1", 10) || 1);

const result = await getCommunityPostPaginated(postId, page);
if (!result) return new Response(null, { status: 404 });

const { post, pagination } = result;

const session = Astro.locals.user;

let isSubscribed = false;
if (session) {
	const subscriber = await communityRepository.getSubscriber(post.communityId, session.id);
	isSubscribed = !!subscriber;
}

const isOwner = session?.id === community.ownerId;

const baseUrl = `/comunidades/${slug}/${postId}`;

const seo = {
	title: post.title,
	description: post.content.slice(0, 150),
};
---

<Layout {...seo}>
	<CommunityHeader community={community} isSubscribed={isSubscribed} isOwner={isOwner} />

	<CommunityPostDetail post={post} pagination={pagination} baseUrl={baseUrl} />

	{
		isSubscribed && (
			<div class="mt">
				<CreateResponseForm postId={post.id} client:load />
			</div>
		)
	}
</Layout>
