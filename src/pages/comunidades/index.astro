---
import Layout from "@layout/Main.astro";
import CommunityListItem from "@components/community/CommunityListItem/CommunityListItem.astro";
import Pagination from "@components/_shared/Pagination/Pagination.astro";
import { getCommunities } from "@services/community";

const pageParam = Astro.url.searchParams.get("page");
const page = Math.max(1, parseInt(pageParam ?? "1", 10) || 1);

const { items: communities, pagination } = await getCommunities(page);

if (page > pagination.totalPages) {
	return Astro.redirect(`?page=${pagination.totalPages}`, 307);
}

const seo = {
	title: "Comunidades",
	description: "Descubra e participe de comunidades temáticas no Gugugram.",
};
---

<Layout {...seo}>
	<div class="flex justify-between center mb">
		<h2>Comunidades</h2>
		<a href="/comunidades/criar" class="button">Nova comunidade</a>
	</div>

	<div class="field-border links-list p">
		{
			communities.length === 0 ? (
				<p class="text-muted">Nenhuma comunidade ainda. Seja o primeiro a criar uma!</p>
			) : (
				<ul class="unstyled">
					{communities.map((community) => (
						<li>
							<CommunityListItem {community} />
						</li>
					))}
				</ul>
			)
		}
	</div>

	<Pagination page={pagination.page} totalPages={pagination.totalPages} />
</Layout>

<style>
	.community-grid {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}
</style>
