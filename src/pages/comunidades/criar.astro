---
import Layout from "@layout/Main.astro";
import CreateCommunityForm from "@components/community/CreateCommunityForm/CreateCommunityForm.svelte";

const session = Astro.locals.user;
if (!session) return Astro.redirect("/entrar");

const seo = {
	title: "Criar comunidade",
	robots: "noindex,nofollow",
};
---

<Layout {...seo}>
	<CreateCommunityForm client:load />
</Layout>
