---
import Layout from "@layout/Main.astro";
import { getLatestImagePosts } from "@services/imagePost";
import ImagePostList from "@components/post/ImagePostList/ImagePostList.astro";

const latestImagePosts = await getLatestImagePosts();

const seo = {
	description: "Conheça as últimas imagens que subiram na rede social Gugugram!",
};
---

<Layout {...seo}>
	<p>
		A sua rede social de compartilhar imagens feitas com 5px², 10px², 15px², 20px², 30px² e 60px².
	</p>
	<h2>Últimas imagens</h2>
	<ImagePostList posts={latestImagePosts} />
</Layout>
