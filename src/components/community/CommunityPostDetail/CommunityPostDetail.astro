---
import CommunityResponseList from "@components/community/CommunityResponseList/CommunityResponseList.astro";
import Pagination from "@components/_shared/Pagination/Pagination.astro";
import type { CommunityPostDetailType } from "@customTypes/community";

interface Props {
	post: CommunityPostDetailType;
	pagination: {
		page: number;
		totalPages: number;
		totalCount: number;
	};
	baseUrl: string;
}

const { post, pagination, baseUrl } = Astro.props;

const createdAt = post.createdAt.toLocaleString("pt-BR", {
	day: "2-digit",
	month: "2-digit",
	year: "numeric",
	hour: "2-digit",
	minute: "2-digit",
});
---

<article class="post-detail window mt">
	<div class="title-bar">
		<p><strong>{post.title}</strong></p>
	</div>
	<div class="window-body">
		<p class="text-muted meta">
			por <a href={`/${post.authorUsername}`}>{post.authorUsername}</a> · {createdAt}
		</p>
		<div class="content field-border p">
			<p>{post.content}</p>
		</div>
		<div class="mt">
			<CommunityResponseList responses={post.responses} totalCount={pagination.totalCount} />
			<Pagination page={pagination.page} totalPages={pagination.totalPages} baseUrl={baseUrl} />
		</div>
	</div>
</article>

<style>
	.meta {
		margin: 0 0 8px;
	}

	.content {
		background-color: var(--button-highlight);
	}

	.content p {
		margin: 0;
		white-space: pre-wrap;
		word-break: break-word;
	}
</style>
