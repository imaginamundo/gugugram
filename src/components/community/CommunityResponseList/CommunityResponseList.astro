---
import CommunityResponseCard from "@components/community/CommunityResponseCard/CommunityResponseCard.astro";
import type { CommunityResponseType } from "@customTypes/community";

interface Props {
	responses: CommunityResponseType[];
	totalCount?: number;
}

const { responses, totalCount } = Astro.props;

// Responses come from the service already ordered oldest-first (ASC createdAt)
const count = totalCount ?? responses.length;
---

<section class="response-list">
	<h2 class="response-count">
		{count}
		{count === 1 ? "resposta" : "respostas"}
	</h2>
	{
		responses.length === 0 ? (
			<p class="text-muted">Nenhuma resposta ainda. Seja o primeiro a responder!</p>
		) : (
			<div class="flex flex-col gap">
				{responses.map((response) => (
					<CommunityResponseCard response={response} />
				))}
			</div>
		)
	}
</section>

<style>
	.response-count {
		margin: 0 0 8px;
	}
</style>
